; level traders first (alch, surg, fortune teller)
; long process haltable (right cntrl+alt+h default)
InvestInGreenMedsAndPotionOfLuck() {
    global
    haltLongProcessFlag := false

    ; PART 1, BUY LUCK (we must start right side of the new alchemist for positioning sake)
    GoToAlchemist()
    SS()
    MouseClick "left", 69, 335
    SS()

    if haltLongProcessFlag    ; stop point 1
      return
    FillAllMakeDeal()

    ; PART  2, GREEN BANDOS
    SS()
    MouseClick "left", 532, 302 ; set of triple green Bandages
    SS()
    if haltLongProcessFlag    ; stop point 2
      return
    FillAllMakeDeal()
    ;    SS()
    MouseClick "left", 401, 302 ; set of single green Bandages
    SS()
    Loop 2 {  ; click increase
      MouseClick "left", 1013, 604 
      MS()
    }
    if haltLongProcessFlag      ; stop point 3
      return
    FillAllMakeDeal()

    ; PART 3/3, GREEN POTS
    SS()
    MouseClick "left", 285, 302 ; set of triple green potions
    SS()
    if haltLongProcessFlag    ; stop point 4 
      return
    FillAllMakeDeal()
    SS()
    MouseClick "left", 157, 302 ; set of single green potions
    SS()
    Loop 2 {  ; click increase
      HoverMouseThenClick(1013, 604)
      MS()
    }
    if haltLongProcessFlag    ; stop point 5
      return
    FillAllMakeDeal()
}


