; aux functions
SwapToLastCharacterOnFrontPage() {
  GlobalBack()
  ; log out of character
  ; MouseClick "left",  237, 44   ; click play button  - dont need?
  LS()
  HoverMouseThenClick(1858, 1025)  ; change class button
  Loop 4 {
    VLS()   ; accounting for long loading times potentially
  }
  HoverMouseThenClick(1680, 780)  ; click on 6nd character down
  LS()
  HoverMouseThenClick(954, 979)  ; Enter the lobby button
  Loop 6 {
    VLS()  ; accounting for long loading times potentially
  }
}

