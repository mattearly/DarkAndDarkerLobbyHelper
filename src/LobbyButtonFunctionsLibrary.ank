; resets right side bow and left side potions, clears chat, hits play
ResetSquireRSBLSP() {
  global
  GlobalBack()
  HoverMouseThenClick(MerchantsTopMenuLoc[1], MerchantsTopMenuLoc[2])
  SS()
  MouseClick "left", SquireLoc[1], SquireLoc[2]
  SS()

  ; unequip right side weapon slot, R clicking sheild or offhand slot
