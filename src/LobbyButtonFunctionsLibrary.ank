; a very long routine that gathers all expressman loot and all goblin buyback loot
; from your last 6 played characters
FrontPageOfCharactersGoblinBuybackAndExpressmanGather() { 
  Loop 6 {
    if (haltLongProcessFlag)
      continue
    GoToGoblinBuy()
    LS()
    MouseClick "left", 296, 139  ; Service button
    LS()
    MouseClick "left", 306, 1011  ; select all button
    LS()
    SS()
    MouseClick "left", RetrievalFillAllLoc[1],RetrievalFillAllLoc[2]  ; fill all
    SS()
    MouseClick "left", RetrievalFillAllLoc[1],RetrievalFillAllLoc[2]+60  ; get item 
    LS()
    ExpressmanExpress()
    LS()
    SwapToLastCharacterOnFrontPage()
  } 
}

